generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         BigInt   @id

  firstName  String
  username   String?
  language   String   @default("uk")

  // Контакти зі сцени
  phone      String?
  email      String?

  // ── CRM-синхронізація ─────────────────────────────────────────────────────
  //
  // crmSynced — чи вдалось успішно створити лід у CRM.
  //   false = ще не синхронізовано або CRM повернув помилку
  //   true  = лід створено
  //
  // crmLeadId — числовий ID ліда у Uspacy (поле "id" у відповіді CRM).
  //   Дозволяє у майбутньому відкривати лід напряму або оновлювати його.
  //   null якщо синхронізація не відбувалась або не вдалась.
  //
  crmSynced  Boolean  @default(false)
  crmLeadId  Int?

  createdAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt
  events     Event[]
}

model Event {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  user      User     @relation(fields: [userId], references: [id])
  action    String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
